{
  "name": "annotakit",
  "version": "0.1.0",
  "description": "Floating toolbar for SvelteKit apps — annotate UI elements and generate structured markdown feedback for AI coding agents",
  "license": "MIT",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./dist/styles/theme.css"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package -o dist",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5.35.0"
  },
  "dependencies": {
    "bits-ui": "^1.3.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "svelte": "^5.35.0",
    "svelte-check": "^4.2.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "annotation",
    "toolbar",
    "developer-tools",
    "ai-feedback",
    "claude",
    "cursor"
  ],
  "author": "nodestarQ",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthropics/annotakit.git"
  }
}
